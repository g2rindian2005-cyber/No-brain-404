<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar" id="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <span class="logo-icon"><i class="fa-solid fa-circle-nodes"></i></span>
      <span class="logo-text">Tech<span class="accent">Solve</span></span>
    </a>

    <div class="nav-search">
      <form action="/search" method="GET" class="search-form">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input type="text" name="q" placeholder="Search problems & solutions..." class="search-input" id="globalSearch" autocomplete="off" />
        <div class="search-suggestions" id="searchSuggestions"></div>
      </form>
    </div>

    <div class="nav-links">
      <a href="/submit" class="btn-submit"><i class="fa-solid fa-plus"></i> Share Solution</a>
      <button class="theme-toggle" id="themeToggle" title="Toggle Theme">
        <i class="fa-solid fa-moon" id="themeIcon"></i>
      </button>
      <div class="auth-area" id="authArea">
        <a href="/login" class="btn-auth">Login</a>
        <a href="/signup" class="btn-auth btn-signup">Sign Up</a>
      </div>
      <div class="user-menu hidden" id="userMenu">
        <button class="user-avatar-btn" id="userAvatarBtn">
          <img src="" alt="" class="user-avatar" id="userAvatarImg" />
          <span id="userNameDisplay"></span>
          <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="dropdown-menu" id="dropdownMenu">
          <a href="/profile"><i class="fa-solid fa-user"></i> My Profile</a>
          <a href="/submit"><i class="fa-solid fa-pen-to-square"></i> Share Solution</a>
          <div id="adminMenuItems" class="hidden">
            <hr />
            <a href="/admin"><i class="fa-solid fa-shield-halved"></i> Admin Panel</a>
          </div>
          <hr />
          <a href="#" id="logoutBtn"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
        </div>
      </div>
      <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fa-solid fa-bars"></i></button>
    </div>
  </div>

  <!-- Category Nav -->
  <div class="category-nav" id="categoryNav">
    <div class="category-nav-inner" id="categoryNavInner">
      <a href="/" class="cat-link <%= currentPath === '/' ? 'active' : '' %>"><i class="fa-solid fa-house"></i> All</a>
      <!-- Populated by JS -->
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu hidden" id="mobileMenu">
  <a href="/">Home</a>
  <a href="/submit">Share Solution</a>
  <a href="/login">Login</a>
  <a href="/signup">Sign Up</a>
</div>

<!-- MAIN CONTENT -->
<main class="main-content">
  <%- body %>
</main>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <a href="/" class="nav-logo">
        <span class="logo-icon"><i class="fa-solid fa-circle-nodes"></i></span>
        <span class="logo-text">Tech<span class="accent">Solve</span></span>
      </a>
      <p>A community where tech professionals share real-world problems and battle-tested solutions.</p>
    </div>
    <div class="footer-links">
      <h4>Categories</h4>
      <div id="footerCategories"></div>
    </div>
    <div class="footer-links">
      <h4>Platform</h4>
      <a href="/submit">Share a Solution</a>
      <a href="/search">Search Issues</a>
      <a href="/login">Login</a>
      <a href="/signup">Join Community</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <%= new Date().getFullYear() %> TechSolve. Built by the community, for the community.</p>
  </div>
</footer>

<script>
  window.API_URL = '<%= API_URL %>';
</script>
<script src="/js/app.js"></script>
</body>
</html>
